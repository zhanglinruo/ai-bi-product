# ============================================
# AI+BI 系统配置文件
# ============================================

# 服务配置
NODE_ENV=development
PORT=3000

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=ai_bi_test

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# ============================================
# 千帆大模型配置
# ============================================

# API 地址
LLM_BASE_URL=https://qianfan.baidubce.com/v2/coding

# API Key（请填写你的 API Key）
LLM_API_KEY=

# 模型名称
LLM_MODEL=qianfan-code-latest

# 温度参数 (0-1)
LLM_TEMPERATURE=0.3

# 最大 Token 数
LLM_MAX_TOKENS=2000
